{
  "name": "cadviewer-conversion-server",
  "version": "11.4.5",
  "description": "CADViewer NodeJS Server Encapsulation of CAD Converters",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "start:ts": "node dist/app.js",
    "run": "node app.js",
    "dev": "nodemon app.js",
    "dev:ts": "ts-node-dev --respawn --transpile-only app.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "author": "charnung",
  "license": "TMS 1.0",
  "dependencies": {
    "aws-serverless-express": "^3.4.0",
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "diskusage": "^1.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.1",
    "express-basic-auth": "^1.2.1",
    "formidable": "^1.2.2",
    "image-size": "^1.0.0",
    "is-gzip": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.2",
    "node-fetch": "^2.7.0",
    "node-gyp": "^8.1.0",
    "node-os-utils": "^1.3.7",
    "node-schedule": "^2.1.1",
    "nodemailer": "^7.0.11",
    "nodemon": "^3.0.1",
    "read-excel-file": "^5.8.5",
    "zod": "^3.24.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CADViewer/cadviewer-conversion-server"
  },
  "bugs": {
    "url": "https://github.com/CADViewer"
  },
  "homepage": "https://cadviewer.com",
  "keywords": [
    "CAD",
    "javascript",
    "CAD Viewer",
    "DWG",
    "DXF",
    "DWF",
    "PDF",
    "DGN",
    "TIFF",
    "Annotate",
    "Redline",
    "Space Management",
    "CAFM",
    "IOT",
    "Asset Management",
    "IWMS"
  ],
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/formidable": "^1.2.8",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^18.19.130",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.21",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
